[app]
title = WingPay Enterprise Sync
package.name = wingpay
package.domain = com.inversioneswing
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 65.5-STARK
requirements = python3,kivy,plyer,android,requests,certifi
orientation = portrait
osx.python_version = 3
osx.kivy_version = 1.9.1
fullscreen = 0
android.permissions = INTERNET, POST_NOTIFICATIONS, FOREGROUND_SERVICE, FOREGROUND_SERVICE_REMOTE_MESSAGING
android.api = 34
android.minapi = 21
android.sdk = 34
android.ndk = 25b
android.archs = arm64-v8a, armeabi-v7a
android.allow_backup = True


